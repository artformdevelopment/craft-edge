{
  "name": "artformdev/craft-edge",
  "description": "Full-page HTML edge caching for Craft CMS at one edge tier (nginx or Cloudflare), with exact element-driven invalidation and CSRF/session-safe hydration.",
  "type": "craft-plugin",
  "license": "proprietary",
  "support": {
    "email": "hello@artformdev.com"
  },
  "authors": [
    {
      "name": "ArtformDev",
      "email": "hello@artformdev.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "craftcms/cms": "^5.0"
  },
  "require-dev": {
    "craftcms/ecs": "dev-main",
    "craftcms/phpstan": "dev-main",
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "artformdev\\edge\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "artformdev\\edge\\tests\\": "tests/"
    }
  },
  "extra": {
    "handle": "edge",
    "name": "Edge",
    "developer": "ArtformDev",
    "class": "artformdev\\edge\\Plugin"
  },
  "scripts": {
    "check-cs": "ecs check --ansi",
    "fix-cs": "ecs check --ansi --fix",
    "phpstan": "phpstan --memory-limit=1G",
    "test": "phpunit"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "yiisoft/yii2-composer": true,
      "craftcms/plugin-installer": false
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
